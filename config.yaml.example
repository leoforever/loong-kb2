# 龙芯知识库配置文件示例
# 请复制此文件为 config.yaml 并填写真实值

# 服务配置
server:
  host: "0.0.0.0"
  port: 5001

# LLM 配置
# provider: 当前支持 minimax / qwen，切换只需改这一行
llm:
  provider: "minimax"
  max_tokens: 2048   # 生成回答的最大 token 数

# MiniMax LLM 配置（provider=minimax 时生效）
minimax:
  api_key: "YOUR_MINIMAX_API_KEY"
  base_url: "https://api.minimaxi.com/anthropic"
  model: "MiniMax-M2.7"

# Qwen LLM 配置（provider=qwen 时生效）
qwen:
  base_url: "http://YOUR_QWEN_SERVER:PORT"
  model: "Qwen3.5-27B-W8A8"

# Dify 全局默认 API 配置（新建知识库时的默认值）
dify:
  api_url: "http://YOUR_DIFY_SERVER/v1"
  api_key: "YOUR_DIFY_API_KEY"

# Embedding 模型配置（用于本地 QA 知识库向量检索）
# provider: ollama | openai | siliconflow
embedding:
  provider: "siliconflow"
  ollama:
    url: "http://127.0.0.1:11434/api/embeddings"
    model: "bge-m3:latest"
  openai:
    api_key: "YOUR_OPENAI_API_KEY"
    base_url: "https://api.openai.com/v1"
    model: "text-embedding-3-small"
  siliconflow:
    api_key: "YOUR_SILICONFLOW_API_KEY"
    model: "BAAI/bge-m3"

# Reranker 模型配置（QA 回答前对 Dify 返回的 chunks 二次精筛）
# provider: siliconflow | None（不启用则跳过 reranker，直接用 Dify 原排序）
reranker:
  provider: "siliconflow"
  score_threshold: 0.3   # rerank score 低于此值的 chunk 丢弃
  siliconflow:
    api_key: "YOUR_SILICONFLOW_API_KEY"
    model: "BAAI/bge-reranker-v2-m3"
    base_url: "https://api.siliconflow.cn"   # 末尾不带 /v1，程序自动拼接
